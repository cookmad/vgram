<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>ダミーページ</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            background-color: #000;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            overflow: hidden;
        }

        /* スマホ風の縦長コンテナ */
        .reel-container {
            position: relative;
            width: 100%;
            max-width: 450px; /* PC閲覧時の最大幅 */
            height: 100dvh;
            background-color: #222;
            overflow: hidden;
        }

        /* 背景の縦型動画 */
        .reel-video {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        /* 動画の暗転グラデーション（テキストを読みやすくするため） */
        .overlay-gradient {
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            height: 40%;
            background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0) 100%);
            pointer-events: none;
        }

        /* 右側のアイコン群 */
        .actions-sidebar {
            position: absolute;
            bottom: 30px;
            right: 15px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 20px;
            z-index: 10;
        }

        .action-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            color: #fff;
            text-shadow: 1px 1px 2px rgba(0,0,0,0.5);
        }

        .action-item i {
            font-size: 28px;
            margin-bottom: 5px;
        }

        .action-item.heart i {
            color: #ff3040; /* いいねを赤色に */
        }

        .action-item span {
            font-size: 13px;
            font-weight: bold;
        }

        /* 下部のテキスト・コメント群 */
        .bottom-info {
            position: absolute;
            bottom: 30px;
            left: 15px;
            width: calc(100% - 80px); /* 右側のアイコンと被らないように調整 */
            color: #fff;
            z-index: 10;
            text-shadow: 1px 1px 2px rgba(0,0,0,0.5);
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 10px;
        }

        .user-icon {
            width: 36px;
            height: 36px;
            background-color: #ccc; /* ダミーのアイコン画像領域 */
            border-radius: 50%;
            border: 1px solid rgba(255,255,255,0.2);
        }

        .username {
            font-weight: bold;
            font-size: 15px;
        }

        .caption-text {
            font-size: 14px;
            line-height: 1.4;
            margin-bottom: 8px;
            display: -webkit-box;
            -webkit-line-clamp: 3; /* 3行で三点リーダー表示 */
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        /* 流し込み用のコメントセクション */
        .comments-section {
            background: rgba(0, 0, 0, 0.4);
            border-radius: 12px;
            padding: 8px 12px;
            margin-top: 10px;
            max-height: 100px;
            overflow-y: auto;
        }

        .comment-item {
            font-size: 13px;
            margin-bottom: 6px;
            line-height: 1.3;
        }

